{
  "name": "gewu",
  "version": "1.0.0",
  "private": true,
  "description": "Academic assistant monorepo scaffold",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,admin,api,worker -c cyan,magenta,green,yellow \"npm run dev -w web\" \"npm run dev -w admin\" \"npm run dev -w api\" \"npm run dev -w worker\"",
    "dev:web": "npm run dev -w web",
    "dev:admin": "npm run dev -w admin",
    "dev:api": "npm run dev -w api",
    "dev:worker": "npm run dev -w worker",
    "build": "npm run build -w web && npm run build -w admin && npm run build -w api && npm run build -w worker",
    "lint": "npm run check:encoding && npm run lint -w web && npm run lint -w admin",
    "check:encoding": "node scripts/check-mojibake.mjs",
    "smoke:task-security": "node scripts/smoke-task-security.mjs",
    "smoke:auth-lifecycle": "node scripts/smoke-auth-lifecycle.mjs",
    "smoke:admin-auth": "node scripts/smoke-admin-auth.mjs",
    "smoke:payment-refund": "node scripts/smoke-payment-refund.mjs",
    "smoke:admin-ban": "node scripts/smoke-admin-ban.mjs",
    "smoke:admin-dashboard": "node scripts/smoke-admin-dashboard.mjs",
    "smoke:model-api-key": "node scripts/smoke-model-api-key.mjs",
    "smoke:content-tutorials": "node scripts/smoke-content-tutorials.mjs",
    "smoke:admin-action-logs": "node scripts/smoke-admin-action-logs.mjs",
    "smoke:admin-settings": "node scripts/smoke-admin-settings.mjs",
    "smoke:email-notifications": "node scripts/smoke-email-notifications.mjs",
    "smoke:workbench-nav": "node scripts/smoke-workbench-nav.mjs",
    "smoke:docx-local": "node scripts/smoke-docx-local.mjs",
    "smoke:docx-content-extraction": "node scripts/smoke-docx-content-extraction.mjs",
    "smoke:docx-repricing": "node scripts/smoke-docx-repricing.mjs",
    "smoke:docx-worker-callback": "node scripts/smoke-docx-worker-callback.mjs",
    "smoke:workbench-browser": "node scripts/smoke-workbench-browser.mjs",
    "smoke:points-concurrency": "node scripts/smoke-points-concurrency.mjs",
    "smoke:core-algorithms": "node scripts/smoke-core-algorithms.mjs",
    "smoke:detect-pdf": "node scripts/smoke-detect-pdf-report.mjs",
    "smoke:execution-routing": "node scripts/smoke-execution-mode-routing.mjs",
    "smoke:rewrite-spec": "npm run build -w api && node scripts/smoke-rewrite-spec.mjs",
    "smoke:rewrite-shared": "npm run build -w api && node scripts/smoke-rewrite-shared-rules.mjs",
    "smoke:plans-crud": "node scripts/smoke-plans-crud.mjs",
    "smoke:longform-task": "node scripts/smoke-longform-task.mjs",
    "smoke:docx-guardrails": "node scripts/smoke-docx-guardrails.mjs",
    "smoke:critical": "node scripts/smoke-critical.mjs",
    "screenshots:original": "node scripts/screenshot-original.mjs",
    "screenshots:current": "node scripts/screenshot-current.mjs",
    "screenshots:current:local": "node scripts/screenshot-current-local.mjs",
    "compare:screenshots": "node scripts/compare.js",
    "screenshots:core:original": "node scripts/screenshot-core-original.mjs",
    "screenshots:core:current:local": "node scripts/screenshot-core-current-local.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "concurrently": "^9.2.1",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7"
  }
}
