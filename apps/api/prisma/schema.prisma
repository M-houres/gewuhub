generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum TaskType {
  DETECT
  REWRITE
  LITERATURE_REVIEW
  PROPOSAL
}

enum TaskStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id              String         @id @default(cuid())
  email           String?        @unique
  phone           String?        @unique
  password        String?
  inviteCode      String?        @unique
  invitedBy       String?
  role            UserRole       @default(USER)
  points          Int            @default(0)
  agentPoints     Int            @default(0)
  dailyDetectUsed Int            @default(0)
  emailVerified   Boolean        @default(false)
  lastCheckinAt   DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tasks           Task[]
  pointRecords    PointRecord[]
  orders          Order[]
  referrals       Referral[]

  @@index([createdAt])
  @@index([role, createdAt])
  @@index([invitedBy])
}

model Referral {
  id              String   @id @default(cuid())
  userId          String
  referredUserId  String
  rewardPoints    Int      @default(0)
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([referredUserId])
}

model Task {
  id          String    @id @default(cuid())
  type        String
  status      String    @default("queued")
  payload     Json
  result      Json?
  pointsCost  Int       @default(0)
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([type, status])
}

model ModelConfig {
  id              String   @id @default(cuid())
  provider        String
  modelId         String
  displayName     String
  apiKeyEncrypted String?
  enabled         Boolean  @default(true)
  pointMultiplier Float    @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([provider, modelId])
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  billingType String
  price       Float
  quota       Int
  features    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id         String   @id @default(cuid())
  userId     String
  planName   String
  amount     Float
  status     String   @default("pending")
  payMethod  String?
  tradeNo    String?  @unique
  paidAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([tradeNo])
}

model PaymentConfig {
  id          String   @id @default(cuid())
  provider    String   @unique
  enabled     Boolean  @default(false)
  config      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PromotionConfig {
  id                String   @id @default(cuid())
  key               String   @unique
  value             Json
  description       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PointRecord {
  id        String   @id @default(cuid())
  userId    String
  change    Int
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model Platform {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  enabled     Boolean  @default(false)
  sortOrder   Int      @default(0)
  taskTypes   Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  rulePackages RulePackage[]

  @@index([enabled, sortOrder])
}

model RulePackage {
  id          String   @id @default(cuid())
  platformId  String
  taskType    String
  version     String
  rules       Json
  hash        String
  status      String   @default("draft")
  isActive    Boolean  @default(false)
  uploadedBy  String?
  notes       String?
  createdAt   DateTime @default(now())
  platform    Platform @relation(fields: [platformId], references: [id])

  @@unique([platformId, taskType, version])
  @@index([platformId, taskType, isActive])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  operator    String
  details     Json
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
