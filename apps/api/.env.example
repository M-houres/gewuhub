# Network
API_PORT=4000
API_HOST=0.0.0.0

# Database / cache
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gewu
STORE_PERSISTENCE_ENABLED=true
REDIS_URL=redis://localhost:6379
ENABLE_QUEUE=false

# Auth / admin
ADMIN_TOKEN=dev-admin-token
ADMIN_USERNAME=admin
ADMIN_PASSWORD=dev-admin-password
ADMIN_ACCESS_TOKEN_TTL_SECONDS=43200
ACCESS_TOKEN_TTL_SECONDS=604800
EMAIL_VERIFY_TOKEN_TTL_SECONDS=1800
PASSWORD_RESET_TOKEN_TTL_SECONDS=1800
EXPOSE_AUTH_DEBUG_TOKENS=true
APP_WEB_BASE_URL=http://127.0.0.1:3000

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_AUTH=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=no-reply@gewu.local
SMTP_FROM_NAME=Gewu

# Payment
PAYMENT_CALLBACK_SECRET=dev-payment-secret
ENABLE_MOCK_PAYMENT=true
DOCX_WORKER_SECRET=dev-docx-worker-secret

# Upload policy
MAX_UPLOAD_SIZE_BYTES=10485760
OSS_ALLOWED_HOSTS=
DOWNLOAD_TICKET_TTL_SECONDS=120
DOCUMENT_FETCH_TIMEOUT_MS=15000

# Input guard
MAX_TASK_CONTENT_CHARS=20000
MAX_MODEL_PROMPT_CHARS=20000

# Rate limits
RATE_LIMIT_AUTH_PER_MINUTE=20
RATE_LIMIT_TASKS_PER_MINUTE=20
RATE_LIMIT_MODEL_ROUTE_PER_MINUTE=30
RATE_LIMIT_PAYMENTS_PER_MINUTE=10
RATE_LIMIT_PAYMENT_NOTIFY_PER_MINUTE=120
RATE_LIMIT_CHECKIN_PER_MINUTE=5
RATE_LIMIT_CLIENT_ERROR_PER_MINUTE=30

# Monitoring
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
APP_ENV=development
RELEASE_VERSION=local
