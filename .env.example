# Public URL served by nginx. Prefer your canonical domain, for example http://restin.top.
# If you also enable www, point it to the same ECS and let nginx redirect www -> apex.
APP_WEB_BASE_URL=http://localhost

# Browser-side API base for the Next.js frontend. Keep /api when using nginx.
NEXT_PUBLIC_API_BASE_URL=/api

# Browser-side API base for the admin frontend. Keep /api when using nginx.
VITE_API_BASE_URL=/api

# Host port exposed by nginx.
NGINX_PORT=80

# PostgreSQL credentials for Docker Compose.
POSTGRES_DB=gewu
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password

# API network.
API_PORT=4000
API_HOST=0.0.0.0

# Auth and admin secrets. Generate strong random values before public launch.
ADMIN_TOKEN=change-me-admin-token
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
ADMIN_ACCESS_TOKEN_TTL_SECONDS=43200
ACCESS_TOKEN_TTL_SECONDS=604800
EMAIL_VERIFY_TOKEN_TTL_SECONDS=1800
PASSWORD_RESET_TOKEN_TTL_SECONDS=1800
EXPOSE_AUTH_DEBUG_TOKENS=false
SEED_DEMO_DATA=false

# SMTP credentials. Use your SMTP provider console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_AUTH=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Gewu

# Payment and worker secrets. Real payment gateway can be added later.
PAYMENT_CALLBACK_SECRET=change-me-payment-callback-secret
GENERATED_FILE_SECRET=change-me-generated-file-secret
ENABLE_MOCK_PAYMENT=true
DOCX_WORKER_SECRET=change-me-docx-worker-secret

# Optional PDF font override. Leave empty to use system fonts (fonts-noto-cjk in Docker / Windows system fonts locally).
PDF_FONT_PATH=

# Upload and download policy. OSS host allowlist can stay empty during local/mock use.
MAX_UPLOAD_SIZE_BYTES=10485760
OSS_ALLOWED_HOSTS=
DOWNLOAD_TICKET_TTL_SECONDS=120
DOCUMENT_FETCH_TIMEOUT_MS=15000

# Input and rate-limit guardrails.
MAX_TASK_CONTENT_CHARS=20000
MAX_MODEL_PROMPT_CHARS=20000
RATE_LIMIT_AUTH_PER_MINUTE=20
RATE_LIMIT_TASKS_PER_MINUTE=20
RATE_LIMIT_MODEL_ROUTE_PER_MINUTE=30
RATE_LIMIT_PAYMENTS_PER_MINUTE=10
RATE_LIMIT_PAYMENT_NOTIFY_PER_MINUTE=120
RATE_LIMIT_CHECKIN_PER_MINUTE=5
RATE_LIMIT_CLIENT_ERROR_PER_MINUTE=30

# Local dev defaults (npm run dev): in-memory store + queue disabled.
# Docker Compose deployment overrides these to production-safe values.
STORE_PERSISTENCE_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
ENABLE_QUEUE=false
API_INTERNAL_BASE_URL=http://127.0.0.1:4000

# Monitoring.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
APP_ENV=production
RELEASE_VERSION=deploy-local

# AI model provider keys (set at least one for real model calls; can also be managed in admin model settings).
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
QWEN_API_KEY=
ERNIE_API_KEY=
GLM_API_KEY=
SPARK_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional provider base URLs. Leave empty to use built-in defaults where available.
DEEPSEEK_BASE_URL=
OPENAI_BASE_URL=
QWEN_BASE_URL=
ERNIE_BASE_URL=
GLM_BASE_URL=
SPARK_BASE_URL=

# Optional API body limit override.
MAX_REQUEST_BODY_BYTES=31457280
